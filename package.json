{
  "name": "2ddecodesim",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "tsx scripts/smoke.ts",
    "electron": "electron .",
    "dist": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.decodesim.app",
    "productName": "DECODE 2D Simulator",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": true
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
