{
  "name": "2ddecodesim",
  "private": true,
  "version": "0.1.0",
  "description": "DSIM — a 2D top-down driver-practice simulator for the FTC 2025-26 game DECODE.",
  "author": "genius0412",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "tsx scripts/smoke.ts",
    "contrast": "node scripts/contrast.mjs",
    "shiftaudit": "electron scripts/shiftaudit.cjs",
    "server": "tsx watch server/index.ts",
    "server:start": "tsx server/index.ts",
    "server:build": "esbuild server/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist-server/index.js",
    "server:prod": "node dist-server/index.js",
    "server:check": "tsc -p tsconfig.server.json",
    "electron": "electron .",
    "dist": "set ELECTRON=1&& npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.decodesim.app",
    "productName": "DSIM",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!node_modules/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": true,
      "artifactName": "DSIM-Setup.${ext}"
    },
    "portable": {
      "artifactName": "DSIM-Portable.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "universal"
        }
      ],
      "identity": null,
      "category": "public.app-category.games",
      "artifactName": "DSIM-mac.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game",
      "artifactName": "DSIM-linux.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "genius0412",
        "repo": "dsim"
      }
    ]
  },
  "dependencies": {
    "@dimforge/rapier2d-compat": "^0.19.3",
    "@neondatabase/auth": "^0.4.2-beta",
    "jose": "^6.1.2",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.23.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.12",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
