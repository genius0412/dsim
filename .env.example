# Multiplayer (optional). Copy to `.env` and set the game-server URL. When this
# is ABSENT the Multiplayer menu is hidden and the solo game is unaffected —
# there is no runtime network dependency.
#
# Phase 0 replaced the old P2P stack (Supabase Realtime + WebRTC mesh + TURN)
# with a single authoritative Node game server (see the `server/` package). Run
# it locally with `npm run server` and point the client at it:
VITE_GAME_SERVER_URL=ws://localhost:8787
#
# MULTI-REGION (optional): to offer players a CHOICE of server, set a LIST as
# JSON instead of the single URL. Each entry needs {id, label, region, url}; the
# client pings every one (/health) so the player picks the lowest latency, and
# the choice is remembered on their account. VITE_GAME_SERVERS takes precedence
# over VITE_GAME_SERVER_URL; keep the single var as a fallback.
# VITE_GAME_SERVERS=[{"id":"us","label":"US East","region":"iad","url":"wss://decode-iad.fly.dev"},{"id":"eu","label":"Europe","region":"lhr","url":"wss://decode-lhr.fly.dev"}]
#
# Each server reports its region via SERVER_REGION (or Fly's FLY_REGION, set
# automatically) — surfaced on /health (x-region header) and /api/presence.
#
# In production, deploy `server/` (e.g. Fly.io) and use its wss:// URL:
# VITE_GAME_SERVER_URL=wss://your-decode-server.fly.dev
#
# On Vercel: add VITE_GAME_SERVER_URL under Project → Settings → Environment
# Variables (baked in at build time — redeploy after a change). For Electron, set
# it in the shell before `npm run dist`.

# --------------------------------------------------------------------------
# Phase 3 — leaderboards / records / ranked ELO (SERVER-SIDE only).
# --------------------------------------------------------------------------
# The game server persists verified scores + replays to Neon Postgres. When
# DATABASE_URL is ABSENT the server still runs matches — only leaderboards/
# records/ELO are disabled. NEVER put these in the client build (VITE_*): the
# server is the only trusted writer.
#
# Neon connection string (includes ?sslmode=require). Set as a Fly SECRET, not
# a build var:  fly secrets set DATABASE_URL='postgres://…' -a dohun-sim-decode
DATABASE_URL=
# optional pool size (default 5)
# DB_POOL_MAX=5
#
# Neon Auth (identity — Better Auth based). ONE client var: the hosted auth
# endpoint on your Neon project, found in the Neon dashboard → Auth tab (looks
# like https://ep-xxx.neonauth.<region>.aws.neon.build/<db>/auth). Safe to
# expose (public). Client SDK: `@neondatabase/auth` → createAuthClient(URL).
# Identity syncs into the Postgres `neon_auth.users_sync` table, so the server
# (which already has DATABASE_URL) attributes runs by joining on the user id.
VITE_NEON_AUTH_URL=
