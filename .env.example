# Multiplayer (optional). Copy to `.env` and set the game-server URL. When this
# is ABSENT the Multiplayer menu is hidden and the solo game is unaffected —
# there is no runtime network dependency.
#
# Phase 0 replaced the old P2P stack (Supabase Realtime + WebRTC mesh + TURN)
# with a single authoritative Node game server (see the `server/` package). Run
# it locally with `npm run server` and point the client at it:
VITE_GAME_SERVER_URL=ws://localhost:8787
#
# MULTI-REGION (optional): to offer players regions, set a LIST as JSON. Each entry
# needs {id, label, region, url}. The client pings every one (/health) so the player
# picks the lowest latency, and the choice is remembered on their account.
# VITE_GAME_SERVERS takes precedence over VITE_GAME_SERVER_URL.
#
#   MODEL M (recommended) — ONE Fly app, one machine per region. All entries share
#   the SAME base url (the app's Anycast hostname); the client adds a ?region= /
#   ?mm= / ?room= hint and the server fly-replays the connection to the right
#   region. Region-local ranked works via Anycast; cross-region ranked/rooms via
#   fly-replay. Deploy: one `fly deploy`, then `fly scale count 1 --region <code>`.
# VITE_GAME_SERVERS=[{"id":"iad","label":"US East","region":"iad","url":"wss://dohun-sim-decode.fly.dev"},{"id":"sjc","label":"US West","region":"sjc","url":"wss://dohun-sim-decode.fly.dev"},{"id":"lhr","label":"Europe","region":"lhr","url":"wss://dohun-sim-decode.fly.dev"},{"id":"syd","label":"Oceania","region":"syd","url":"wss://dohun-sim-decode.fly.dev"},{"id":"nrt","label":"Asia","region":"nrt","url":"wss://dohun-sim-decode.fly.dev"}]
#
#   MODEL S (legacy) — separate app/URL per region (each entry a distinct url).
# VITE_GAME_SERVERS=[{"id":"us","label":"US East","region":"iad","url":"wss://decode-iad.fly.dev"},{"id":"eu","label":"Europe","region":"lhr","url":"wss://decode-lhr.fly.dev"}]
#
# Each server reports its region via SERVER_REGION (or Fly's FLY_REGION, set
# automatically) — surfaced on /health (x-region header) and /api/presence.
#
# MATCHMAKER_REGION (server env, default 'iad'): the region that holds the global
# ranked queue. All ?mm=1 connections fly-replay here; keep min_machines_running=1
# in this region (fly.toml) so it's always warm. Cross-region ranked also needs
# DATABASE_URL (the paired roster is staged in Postgres for the host machine).
# MATCHMAKER_REGION=iad
#
# In production, deploy `server/` (e.g. Fly.io) and use its wss:// URL:
# VITE_GAME_SERVER_URL=wss://your-decode-server.fly.dev
#
# On Vercel: add VITE_GAME_SERVER_URL under Project → Settings → Environment
# Variables (baked in at build time — redeploy after a change). For Electron, set
# it in the shell before `npm run dist`.

# RELEASE CHANNEL of this client build. Default 'stable'. Set to 'alpha' on the
# PRE-RELEASE deployment (e.g. the alpha Vercel project). The server then (a)
# matchmakes alpha players ONLY with other alpha players — they run a different
# src/sim, so mixing channels in one authoritative match desyncs — and (b) does
# NOT persist alpha results to the leaderboard/ELO DB. Stable/omitted ⇒ normal.
# VITE_APP_CHANNEL=alpha

# --------------------------------------------------------------------------
# Phase 3 — leaderboards / records / ranked ELO (SERVER-SIDE only).
# --------------------------------------------------------------------------
# The game server persists verified scores + replays to Neon Postgres. When
# DATABASE_URL is ABSENT the server still runs matches — only leaderboards/
# records/ELO are disabled. NEVER put these in the client build (VITE_*): the
# server is the only trusted writer.
#
# Neon connection string (includes ?sslmode=require). Set as a Fly SECRET, not
# a build var:  fly secrets set DATABASE_URL='postgres://…' -a dohun-sim-decode
DATABASE_URL=
# optional pool size (default 5)
# DB_POOL_MAX=5
#
# Neon Auth (identity — Better Auth based). ONE client var: the hosted auth
# endpoint on your Neon project, found in the Neon dashboard → Auth tab (looks
# like https://ep-xxx.neonauth.<region>.aws.neon.build/<db>/auth). Safe to
# expose (public). Client SDK: `@neondatabase/auth` → createAuthClient(URL).
# Identity syncs into the Postgres `neon_auth.users_sync` table, so the server
# (which already has DATABASE_URL) attributes runs by joining on the user id.
VITE_NEON_AUTH_URL=

# --------------------------------------------------------------------------
# Advertising (Google AdSense). OPTIONAL — absent means NO ads anywhere, no
# script is loaded, and the ad columns never render.
# --------------------------------------------------------------------------
# Set these only AFTER the AdSense application is approved. Approval requires a
# live privacy policy (served at /privacy) and takes days to weeks.
#
# Publisher id from the AdSense dashboard.
# VITE_ADSENSE_CLIENT=ca-pub-0000000000000000
#
# Per-unit slot ids, also from the dashboard. A unit with no slot id stays off,
# so you can enable the menu units before the in-game ones (or vice versa).
#   GAME = the 160x600 skyscrapers flanking the field during a match.
#   MENU = a 300x250 rectangle on the shell pages.
# VITE_ADSENSE_SLOT_GAME=0000000000
# VITE_ADSENSE_SLOT_MENU=0000000000
#
# Ads are suppressed unconditionally in three cases, regardless of these vars:
# the Electron desktop build (AdSense forbids serving in an app wrapper), touch
# devices (no free space — the field would shrink), and supporters.
